{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=smart_choice;User=smart_choice;Password=smart_choice_dev;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8100",
      "http://127.0.0.1:8100",
      "http://localhost",
      "capacitor://localhost"
    ]
  },
  "Database": {
    "AutoMigrateOnStartup": true,
    "SeedDevDataOnStartup": true
  },
  "Auth": {
    "Issuer": "smart-choice-api",
    "Audience": "smart-choice-client",
    "SigningKey": "dev_only_change_me_to_a_long_32_char_secret_key",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14,
    "GuestTokenHours": 24
  },
  "ObjectStorage": {
    "BucketName": "smart-choice-polls-dev",
    "Region": "us-east-1",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "ServiceUrl": "http://localhost:9000",
    "PublicBaseUrl": "http://localhost:9000",
    "ForcePathStyle": true,
    "EnsureBucketExistsOnStartup": true,
    "MakeBucketPublicOnStartup": true,
    "ThumbnailWidth": 480,
    "MaxUploadBytes": 10485760
  }
}
